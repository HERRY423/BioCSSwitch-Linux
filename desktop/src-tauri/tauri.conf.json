{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BioCSSwitch",
  "version": "0.4.1",
  "identifier": "com.biocsswitch.menubar",
  "build": {
    "beforeBuildCommand": "python3 ../scripts/vendor-python-runtime.py",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BioCSSwitch",
        "width": 1180,
        "height": 780,
        "minWidth": 760,
        "minHeight": 620,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "visible": true,
        "center": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../../proxy": "proxy",
      "../../scripts": "scripts",
      "../../packs": "packs",
      "../../python-vendor": "python-vendor"
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
