{
  "id": "bio-mcp-shim",
  "name": "远程 MCP 本地替身层",
  "description": "Anthropic 托管的远程 MCP（pubmed / clinical-trials / chembl / biorxiv 位于 *.mcp.claude.com）在虚拟登录下被代理 fast-fail。这个 pack 用**本地 MCP**假冒它们，用同名（pubmed / clinical-trials / chembl / biorxiv）挂进沙箱，让 Science 的工具列表看起来仍然有这些远程 MCP，实际流量走本地 API + 用户填的 key。",
  "version": "0.1.0",
  "requires_env": [],
  "optional_env": [
    {"name": "NCBI_API_KEY",     "label": "NCBI API Key（PubMed 提高配额）"},
    {"name": "NCBI_EMAIL",       "label": "NCBI 联系邮箱"},
    {"name": "CROSSREF_MAILTO",  "label": "Crossref polite pool 邮箱"}
  ],
  "task_tags": ["lit-review", "clinical-trials", "target-discovery", "tool-heavy"],
  "servers": [
    {
      "name": "bio-mcp-shim-pubmed",
      "script": "packs/bio-mcp-shim/pubmed_shim.py",
      "env_pass": ["NCBI_API_KEY", "NCBI_EMAIL"],
      "aliases": ["pubmed"]
    },
    {
      "name": "bio-mcp-shim-clinical-trials",
      "script": "packs/bio-mcp-shim/ctgov_shim.py",
      "aliases": ["clinical-trials"]
    },
    {
      "name": "bio-mcp-shim-chembl",
      "script": "packs/bio-mcp-shim/chembl_shim.py",
      "aliases": ["chembl"]
    },
    {
      "name": "bio-mcp-shim-biorxiv",
      "script": "packs/bio-mcp-shim/biorxiv_shim.py",
      "aliases": ["biorxiv"]
    }
  ]
}
