    {"name": "CellTypist", "kind": "python", "required": false, "purpose": "Generated cell type annotation workflows"},
    {"name": "SingleR", "kind": "R/Bioconductor", "required": false, "purpose": "Generated R annotation workflows"},
    {"name": "Nextflow", "kind": "workflow", "required": false, "purpose": "Generated Nextflow workflow package"},
    {"name": "Snakemake", "kind": "workflow", "required": false, "purpose": "Generated Snakemake workflow package"}
