{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://biocsswitch.local/schemas/pack.schema.json",
  "title": "BioCSSwitch Pack Manifest",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "name", "description", "version", "dependencies", "requires_tools", "servers"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {"type": "string", "minLength": 1},
    "description": {"type": "string", "minLength": 1},
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"
    },
    "dependencies": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
      "uniqueItems": true,
      "default": []
    },
    "depends_on": {
      "type": "array",
      "items": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
      "uniqueItems": true,
      "default": [],
      "description": "Deprecated compatibility alias for dependencies."
    },
    "requires_tools": {
      "type": "array",
      "items": {"$ref": "#/$defs/toolRequirement"},
      "default": []
    },
    "requires_env": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "optional_env": {
      "type": "array",
      "items": {"$ref": "#/$defs/optionalEnv"},
      "default": []
    },
    "task_tags": {
      "type": "array",
      "items": {"type": "string"},
      "default": []
    },
    "servers": {
      "type": "array",
      "items": {"$ref": "#/$defs/server"},
      "default": []
    },
    "skills": {
      "type": "array",
      "items": {"$ref": "#/$defs/skill"},
      "default": []
    }
  },
  "$defs": {
    "toolRequirement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": {"type": "string", "minLength": 1},
        "kind": {"type": "string", "default": "runtime"},
        "required": {"type": "boolean", "default": true},
        "purpose": {"type": "string", "default": ""},
        "install_hint": {"type": "string", "default": ""}
      }
    },
    "optionalEnv": {
      "oneOf": [
        {"type": "string", "minLength": 1},
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name"],
          "properties": {
            "name": {"type": "string", "minLength": 1},
            "label": {"type": "string", "default": ""},
            "url": {"type": "string"}
          }
        }
      ]
    },
    "server": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "script"],
      "properties": {
        "name": {"type": "string", "pattern": "^bio-[a-z0-9-]+$"},
        "script": {"type": "string", "minLength": 1},
        "env_pass": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        },
        "aliases": {
          "type": "array",
          "items": {"type": "string"},
          "default": []
        }
      }
    },
    "skill": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "src"],
      "properties": {
        "id": {"type": "string", "minLength": 1},
        "src": {"type": "string", "minLength": 1}
      }
    }
  }
}
